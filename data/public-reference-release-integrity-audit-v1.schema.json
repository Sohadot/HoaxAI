{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/public-reference-release-integrity-audit-v1.schema.json",
  "title": "Public Reference Release Integrity Audit v1",
  "type": "object",
  "required": [
    "audit_id",
    "name",
    "version",
    "decision_ref",
    "sprint",
    "status",
    "production_first",
    "governance_after_production",
    "new_public_routes_added",
    "expected_sitemap_url_count_after",
    "expected_route_registry_count_after",
    "homepage_snapshot_added",
    "visible_repairs_made",
    "total_repairs_made",
    "homepage_snapshot_counts_as_visible_repair",
    "public_html_checked_only_for_current_forbidden_copy",
    "historical_governance_not_rewritten_for_current_copy_rules",
    "public_file_registry_scope_checked",
    "stale_route_count_language_checked",
    "broken_internal_route_links_checked"
  ],
  "properties": {
    "audit_id": { "const": "public-reference-release-integrity-audit-v1" },
    "decision_ref": { "const": "DEC-118" },
    "sprint": { "const": "Sprint 100" },
    "status": { "const": "public_reference_release_integrity_audit" },
    "production_first": { "const": true },
    "governance_after_production": { "const": true },
    "new_public_routes_added": { "const": false },
    "expected_sitemap_url_count_after": { "const": 58 },
    "expected_route_registry_count_after": { "const": 58 },
    "homepage_snapshot_added": { "const": true },
    "visible_repairs_made": { "const": true },
    "total_repairs_made": { "type": "integer", "minimum": 1 },
    "homepage_snapshot_counts_as_visible_repair": { "const": true },
    "public_html_checked_only_for_current_forbidden_copy": { "const": true },
    "historical_governance_not_rewritten_for_current_copy_rules": { "const": true },
    "public_file_registry_scope_checked": { "const": true },
    "stale_route_count_language_checked": { "const": true },
    "broken_internal_route_links_checked": { "const": true }
  },
  "additionalProperties": true
}
