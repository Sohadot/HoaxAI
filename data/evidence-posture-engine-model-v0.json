{
  "model_id": "evidence-posture-engine-model-v0",
  "name": "Evidence Posture Engine Model v0",
  "version": "0.1.0",
  "status": "internal_non_operational_model",
  "decision_ref": "DEC-086",
  "sprint": "Sprint 68",
  "public_route_authorized": false,
  "public_engine_authorized": false,
  "input_system_authorized": false,
  "output_generator_authorized": false,
  "scoring_authorized": false,
  "api_authorized": false,
  "javascript_authorized": false,
  "source_authority": [
    "evidence_posture_standard_v1",
    "evidence_posture_protocol_v1_draft",
    "engine_boundary_charter"
  ],
  "conceptual_input_categories": [
    "artifact_condition",
    "claim_condition",
    "source_basis",
    "source_confidence",
    "provenance_continuity",
    "context_completeness",
    "claim_source_traceability",
    "evidence_chain_continuity",
    "synthetic_fragility",
    "context_collapse",
    "claim_drift",
    "evidence_limitation",
    "interpretation_risk",
    "attribution_boundary_risk",
    "output_boundary_risk"
  ],
  "protocol_steps": [
    {"step_id": "EP-P01", "name": "Identify the artifact", "model_component": "artifact_condition_dimension"},
    {"step_id": "EP-P02", "name": "Identify the claim", "model_component": "claim_condition_dimension"},
    {"step_id": "EP-P03", "name": "Locate the source basis", "model_component": "source_basis_mapping"},
    {"step_id": "EP-P04", "name": "Assess source confidence", "model_component": "source_confidence_dimension"},
    {"step_id": "EP-P05", "name": "Review provenance continuity", "model_component": "provenance_status_dimension"},
    {"step_id": "EP-P06", "name": "Review context completeness", "model_component": "context_status_dimension"},
    {"step_id": "EP-P07", "name": "Check claim-source traceability", "model_component": "traceability_status_dimension"},
    {"step_id": "EP-P08", "name": "Review evidence chain continuity", "model_component": "chain_status_dimension"},
    {"step_id": "EP-P09", "name": "Check synthetic fragility", "model_component": "synthetic_fragility_signal"},
    {"step_id": "EP-P10", "name": "Check context collapse", "model_component": "context_collapse_signal"},
    {"step_id": "EP-P11", "name": "Check claim drift", "model_component": "drift_status_dimension"},
    {"step_id": "EP-P12", "name": "Define evidence limitation", "model_component": "limitation_status_dimension"},
    {"step_id": "EP-P13", "name": "Assess interpretation risk", "model_component": "interpretation_risk_status_dimension"},
    {"step_id": "EP-P14", "name": "Apply attribution boundary", "model_component": "attribution_boundary_check"},
    {"step_id": "EP-P15", "name": "Apply output boundary", "model_component": "output_boundary_check"},
    {"step_id": "EP-P16", "name": "Assign evidence posture state", "model_component": "posture_state_assignment"},
    {"step_id": "EP-P17", "name": "Produce bounded language only", "model_component": "permitted_output_formation"}
  ],
  "standard_principles": [
    {"principle_id": "EPS-001", "name": "Evidence condition before conclusion"},
    {"principle_id": "EPS-002", "name": "Artifact condition is not subject guilt"},
    {"principle_id": "EPS-003", "name": "Source confidence is not source certification"},
    {"principle_id": "EPS-004", "name": "Provenance gaps limit interpretation but do not prove manipulation"},
    {"principle_id": "EPS-005", "name": "Not Assessable is a valid protected posture"},
    {"principle_id": "EPS-006", "name": "Output must remain inside support boundaries"},
    {"principle_id": "EPS-007", "name": "Claim-source traceability governs claim strength"},
    {"principle_id": "EPS-008", "name": "Synthetic fragility is not automatic falsehood"},
    {"principle_id": "EPS-009", "name": "Context collapse does not prove motive"},
    {"principle_id": "EPS-010", "name": "Evidence chain continuity is not truth certification"},
    {"principle_id": "EPS-011", "name": "Claim drift does not prove deception"},
    {"principle_id": "EPS-012", "name": "Evidence limitation defines responsible speech"},
    {"principle_id": "EPS-013", "name": "Interpretation risk requires output restraint"},
    {"principle_id": "EPS-014", "name": "Attribution boundary prevents subject-transfer overclaim"}
  ],
  "evidence_condition_dimensions": [
    "artifact_condition",
    "claim_condition",
    "source_confidence",
    "provenance_status",
    "context_status",
    "traceability_status",
    "chain_status",
    "drift_status",
    "limitation_status",
    "interpretation_risk_status",
    "attribution_boundary_status",
    "output_boundary_status"
  ],
  "posture_states": [
    "Supported",
    "Qualified",
    "Limited",
    "Not Assessable",
    "Out of Scope"
  ],
  "boundary_checks": [
    "artifact_subject_separation_check",
    "source_confidence_not_certification_check",
    "provenance_gap_not_manipulation_check",
    "context_collapse_not_motive_check",
    "claim_drift_not_deception_check",
    "evidence_limitation_not_falsehood_check",
    "interpretation_risk_not_verdict_check",
    "attribution_boundary_no_subject_transfer_check",
    "output_boundary_no_forbidden_language_check"
  ],
  "permitted_output_types": [
    "posture_state",
    "evidence_condition_summary",
    "source_caveat",
    "provenance_caveat",
    "context_caveat",
    "traceability_caveat",
    "limitation_caveat",
    "interpretation_risk_caveat",
    "attribution_boundary_caveat",
    "bounded_language_template"
  ],
  "prohibited_output_types": [
    "fake/real verdict",
    "truth/falsity verdict",
    "subject guilt",
    "deception intent",
    "manipulation proof",
    "fraud accusation",
    "responsibility assignment",
    "legal conclusion",
    "moderation action",
    "numeric score",
    "confidence percentage",
    "upload classification result",
    "automated enforcement recommendation"
  ],
  "failure_modes": [
    "detector drift",
    "scoring drift",
    "upload implication",
    "fake/real leakage",
    "subject accusation leakage",
    "evidence limitation converted into falsehood",
    "claim drift converted into deception",
    "interpretation risk converted into verdict",
    "source weakness converted into fraud",
    "provenance gap converted into manipulation"
  ],
  "operational_boundaries": {
    "no_public_engine": true,
    "no_classifier": true,
    "no_detector": true,
    "no_scanner": true,
    "no_upload": true,
    "no_scoring": true,
    "no_api": true,
    "no_analytics": true,
    "no_forms": true,
    "no_javascript": true,
    "no_external_outreach": true,
    "no_dns": true,
    "no_monetization": true,
    "no_public_tool_behavior": true
  },
  "last_reviewed": "2026-06-20"
}
