{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/public-reference-release-candidate-integrity-audit-v1.schema.json",
  "title": "Public Reference Release Candidate Integrity Audit v1",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "sprint",
    "status",
    "audit_only",
    "release_candidate_audit",
    "production_route_added",
    "public_route_count_before",
    "public_route_count_after",
    "sitemap_url_count_expected",
    "route_registry_count_expected",
    "public_file_registry_unchanged",
    "phases_checked",
    "release_candidate_records",
    "total_release_candidate_records",
    "walkthrough_scenarios",
    "total_scenarios",
    "scenarios_passed",
    "scenarios_failed",
    "release_candidate_integrity_confirmed",
    "system_coherence_confirmed",
    "cross_phase_integrity_confirmed",
    "new_decision_created",
    "no_new_routes"
  ],
  "properties": {
    "id": { "const": "public-reference-release-candidate-integrity-audit-v1" },
    "sprint": { "const": "Sprint 135" },
    "status": { "const": "public_reference_release_candidate_integrity_audit" },
    "audit_only": { "const": true },
    "release_candidate_audit": { "const": true },
    "production_route_added": { "const": false },
    "public_route_count_before": { "const": 104 },
    "public_route_count_after": { "const": 104 },
    "sitemap_url_count_expected": { "const": 104 },
    "route_registry_count_expected": { "const": 104 },
    "release_candidate_records": { "type": "array", "minItems": 55 },
    "walkthrough_scenarios": { "type": "array", "minItems": 55 },
    "release_candidate_integrity_confirmed": { "const": true },
    "system_coherence_confirmed": { "const": true },
    "cross_phase_integrity_confirmed": { "const": true },
    "new_decision_created": { "type": "boolean" },
    "no_new_routes": { "const": true }
  }
}
