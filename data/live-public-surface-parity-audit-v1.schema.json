{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/live-public-surface-parity-audit-v1.schema.json",
  "title": "Live Public Surface Parity Audit v1",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "sprint",
    "status",
    "audit_only",
    "live_parity_audit",
    "live_base_url",
    "repository_release_candidate_commit",
    "production_route_added",
    "public_route_count_before",
    "public_route_count_after",
    "repository_sitemap_url_count_expected",
    "live_sitemap_url_count_expected",
    "route_registry_count_expected",
    "public_file_registry_unchanged",
    "live_fetch_completed",
    "live_fetch_timestamp_utc",
    "live_access_issue_found",
    "repository_release_candidate_visible_live",
    "live_parity_records",
    "total_live_parity_records",
    "walkthrough_scenarios",
    "total_scenarios",
    "scenarios_passed",
    "scenarios_failed",
    "live_surface_parity_confirmed",
    "repository_integrity_confirmed",
    "new_decision_created",
    "no_new_routes"
  ],
  "properties": {
    "id": { "const": "live-public-surface-parity-audit-v1" },
    "sprint": { "const": "Sprint 136" },
    "status": { "const": "live_public_surface_parity_audit" },
    "audit_only": { "const": true },
    "live_parity_audit": { "const": true },
    "live_base_url": { "const": "https://hoax.ai/" },
    "repository_release_candidate_commit": { "const": "fe7214d" },
    "production_route_added": { "const": false },
    "public_route_count_before": { "const": 104 },
    "public_route_count_after": { "const": 104 },
    "repository_sitemap_url_count_expected": { "const": 104 },
    "live_sitemap_url_count_expected": { "const": 104 },
    "route_registry_count_expected": { "const": 104 },
    "live_parity_records": { "type": "array", "minItems": 60 },
    "walkthrough_scenarios": { "type": "array", "minItems": 60 },
    "repository_integrity_confirmed": { "const": true },
    "new_decision_created": { "type": "boolean" },
    "no_new_routes": { "const": true }
  }
}
