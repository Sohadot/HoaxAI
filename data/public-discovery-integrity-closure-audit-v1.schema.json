{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/public-discovery-integrity-closure-audit-v1.schema.json",
  "title": "Public Discovery Integrity Closure Audit v1",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "sprint",
    "status",
    "audit_only",
    "phase",
    "phase_closure_candidate",
    "production_route_added",
    "public_route_count_before",
    "public_route_count_after",
    "sitemap_url_count_expected",
    "route_registry_count_expected",
    "public_file_registry_unchanged",
    "phase_5_components_checked",
    "discovery_records",
    "total_discovery_records",
    "walkthrough_scenarios",
    "total_scenarios",
    "scenarios_passed",
    "scenarios_failed",
    "public_discovery_integrity_confirmed",
    "phase_5_closure_recommended",
    "new_decision_created",
    "no_new_routes"
  ],
  "properties": {
    "id": { "const": "public-discovery-integrity-closure-audit-v1" },
    "sprint": { "const": "Sprint 134" },
    "status": { "const": "public_discovery_integrity_closure_audit" },
    "audit_only": { "const": true },
    "phase": { "const": "Phase 5" },
    "phase_closure_candidate": { "const": true },
    "production_route_added": { "const": false },
    "public_route_count_before": { "const": 104 },
    "public_route_count_after": { "const": 104 },
    "sitemap_url_count_expected": { "const": 104 },
    "route_registry_count_expected": { "const": 104 },
    "discovery_records": { "type": "array", "minItems": 44 },
    "walkthrough_scenarios": { "type": "array", "minItems": 44 },
    "public_discovery_integrity_confirmed": { "const": true },
    "phase_5_closure_recommended": { "const": true },
    "new_decision_created": { "type": "boolean" },
    "no_new_routes": { "const": true }
  }
}
