{
  "policy_id": "INT-DRAFT-BP-POLICY-001",
  "name": "Hoax.ai Internal Draft Blueprint Policy",
  "version": "v1.0.0",
  "status": "governed_internal_draft_blueprint_policy",
  "maturity": "blueprint_governance_only_no_drafts_no_routes_no_publication",
  "governing_principle": "A draft blueprint is not content. It is the contract content must satisfy before it can exist.",
  "structure_principle": "The first draft must be permitted by structure before it is written by language.",
  "internal_draft_definition": "A non-public, non-route, non-sitemap, non-indexable, governance-bound working artifact that may later be created only after candidate evaluation, draft blueprint approval, claim/source scope, section contracts, semantic SEO boundaries, and validation gates are satisfied.",
  "draft_blueprint_definition": "A structured pre-draft contract that defines the required sections, claim boundaries, source scope, semantic SEO role, prohibited implications, internal link plan, review status, gate dependencies, and non-public status for a future internal draft.",
  "allowed_blueprint_actions": [
    "blueprint_governance_definition",
    "section_contract_definition",
    "state_machine_definition",
    "readiness_gate_definition",
    "template_registry_definition",
    "validation_only"
  ],
  "prohibited_blueprint_actions": [
    "draft_creation",
    "page_creation",
    "route_activation",
    "sitemap_expansion",
    "public_metadata",
    "publication",
    "deployment",
    "dns",
    "cloudflare",
    "tool",
    "classifier",
    "upload",
    "scoring",
    "forms",
    "analytics",
    "external_factual_claims"
  ],
  "required_blueprint_fields": [
    "blueprint_id",
    "candidate_id",
    "candidate_name",
    "candidate_evaluation_ref",
    "blueprint_status",
    "draft_status",
    "route_status",
    "sitemap_status",
    "publication_status",
    "page_family",
    "page_type_ref",
    "reference_thesis",
    "reference_purpose",
    "definition_scope",
    "governance_boundary",
    "claim_scope",
    "source_scope",
    "semantic_seo_role",
    "section_contracts",
    "prohibited_misreadings",
    "forbidden_public_implications",
    "internal_link_plan",
    "structured_data_boundary",
    "interface_boundary",
    "security_privacy_boundary",
    "required_gates",
    "review_status",
    "non_authorization_statement",
    "notes"
  ],
  "required_future_draft_sections": [
    "Draft Thesis",
    "Definition and Scope",
    "Governance Boundary",
    "Relationship to Hoax.ai System",
    "Semantic SEO Role",
    "Claim and Source Traceability",
    "Prohibited Misreadings",
    "Internal Link Plan",
    "Structured Data Boundary",
    "Review Status"
  ],
  "conditional_future_draft_sections": [
    "Taxonomy Relationship",
    "Standard Relationship",
    "Protocol Relationship",
    "Output Boundary Relationship",
    "Candidate Dependency Notes",
    "Source Scope Notes",
    "Publisher Notes"
  ],
  "candidate_eligibility_rules": [
    "only_evaluated_candidates_may_be_considered",
    "readiness_state_draft_blueprint_candidate_eligible",
    "readiness_state_dependency_candidate_eligible",
    "needs_boundary_refinement_not_eligible_until_refinement",
    "no_eligibility_authorizes_draft_creation"
  ],
  "non_authorization_rules": [
    "blueprint_governance_does_not_authorize_drafts",
    "blueprint_governance_does_not_authorize_routes",
    "blueprint_governance_does_not_authorize_sitemap",
    "blueprint_governance_does_not_authorize_publishing",
    "blueprint_governance_does_not_authorize_deployment",
    "blueprint_governance_does_not_authorize_seo_expansion",
    "no_numeric_score_grade_percentage_or_seo_score"
  ],
  "last_reviewed": "2026-06-17"
}
