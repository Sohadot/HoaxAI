{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/internal-prototype-guardrail-red-team-pack-v1.schema.json",
  "title": "Internal Prototype Guardrail Red-Team Pack v1",
  "type": "object",
  "required": [
    "red_team_pack_id",
    "version",
    "status",
    "decision_ref",
    "sprint",
    "public_route_authorized",
    "public_benchmark_authorized",
    "public_report_authorized",
    "output_generator_authorized",
    "scoring_authorized",
    "api_authorized",
    "javascript_authorized",
    "source_authority",
    "red_team_vector_classes",
    "red_team_vectors",
    "forbidden_collapse_targets",
    "required_guardrail_responses",
    "required_red_team_result_fields",
    "failure_conditions",
    "allowed_internal_validation_output",
    "operational_boundaries"
  ],
  "properties": {
    "red_team_pack_id": {
      "type": "string",
      "const": "internal-prototype-guardrail-red-team-pack-v1"
    },
    "version": { "type": "string" },
    "status": {
      "type": "string",
      "const": "internal_non_public_guardrail_red_team_pack"
    },
    "decision_ref": {
      "type": "string",
      "const": "DEC-096"
    },
    "sprint": {
      "type": "string",
      "const": "Sprint 78"
    },
    "public_route_authorized": { "type": "boolean", "const": false },
    "public_benchmark_authorized": { "type": "boolean", "const": false },
    "public_report_authorized": { "type": "boolean", "const": false },
    "output_generator_authorized": { "type": "boolean", "const": false },
    "scoring_authorized": { "type": "boolean", "const": false },
    "api_authorized": { "type": "boolean", "const": false },
    "javascript_authorized": { "type": "boolean", "const": false },
    "source_authority": { "type": "array", "minItems": 6 },
    "red_team_vector_classes": { "type": "array", "minItems": 12 },
    "red_team_vectors": { "type": "array", "minItems": 16 },
    "forbidden_collapse_targets": { "type": "array", "minItems": 13 },
    "required_guardrail_responses": { "type": "array", "minItems": 8 },
    "required_red_team_result_fields": { "type": "array", "minItems": 10 },
    "failure_conditions": { "type": "array", "minItems": 8 },
    "allowed_internal_validation_output": {
      "type": "string",
      "const": "controlled internal guardrail red-team validation passed"
    },
    "operational_boundaries": {
      "type": "object",
      "required": [
        "no_public_benchmark",
        "no_public_report",
        "no_public_engine",
        "no_output_generator",
        "no_upload",
        "no_scoring",
        "no_api",
        "no_javascript",
        "no_public_tool_behavior"
      ],
      "properties": {
        "no_public_benchmark": { "type": "boolean", "const": true },
        "no_public_report": { "type": "boolean", "const": true },
        "no_public_engine": { "type": "boolean", "const": true },
        "no_output_generator": { "type": "boolean", "const": true },
        "no_upload": { "type": "boolean", "const": true },
        "no_scoring": { "type": "boolean", "const": true },
        "no_api": { "type": "boolean", "const": true },
        "no_javascript": { "type": "boolean", "const": true },
        "no_public_tool_behavior": { "type": "boolean", "const": true }
      }
    }
  }
}
