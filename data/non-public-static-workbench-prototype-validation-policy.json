{
  "policy_id": "NP-PROTO-VALIDATION-POLICY-001",
  "name": "Hoax.ai Non-Public Static Workbench Prototype Validation Policy",
  "version": "v1.0.0",
  "status": "governed_non_public_static_workbench_prototype_validation_policy",
  "maturity": "validation_only_static_internal_prototype_no_engine_no_classifier_no_public_route",
  "governing_principle": "A prototype must be validated as non-operational before it can be refined.",
  "identity_principle": "A Hoax.ai prototype must prove its conceptual identity before it earns visual expansion.",
  "allowed_validation_actions": [
    "prototype_validation",
    "static_safety_validation",
    "public_isolation_validation",
    "visual_identity_validation",
    "boundary_audit_validation",
    "publisher_gate_validation",
    "validation_only"
  ],
  "prohibited_actions": [
    "new_prototype_files",
    "prototype_expansion",
    "public_route_creation",
    "sitemap_expansion",
    "public_navigation_link",
    "interface_behavior",
    "javascript",
    "forms",
    "inputs",
    "upload",
    "scoring",
    "fake_real_output",
    "generated_output",
    "engine",
    "classifier",
    "detector",
    "api",
    "analytics",
    "storage",
    "network_calls",
    "monetization",
    "dns",
    "cloudflare",
    "custom_domain_launch",
    "deployment_changes",
    "external_factual_claims",
    "subject_accusation"
  ],
  "validation_scope": [
    "_internal_prototypes/evidence-posture-workbench/index.html",
    "_internal_prototypes/evidence-posture-workbench/prototype.css",
    "prototype_manifest",
    "prototype_surface_map",
    "static_content_contract",
    "boundary_audit",
    "route_registry_exclusion",
    "sitemap_exclusion",
    "public_link_exclusion",
    "publisher_governance",
    "publisher_gates",
    "reference_expansion_gate"
  ],
  "correction_policy": "Corrections cannot add files, routes, sitemap entries, public links, JS, forms, inputs, upload, scoring, engine behavior, classifier behavior, API, analytics, or deployment changes.",
  "non_authorization_rules": {
    "blocked": [
      "public_workbench",
      "workbench_engine",
      "workbench_classifier",
      "upload",
      "scoring",
      "api",
      "new_public_routes",
      "sitemap_expansion",
      "deployment_change",
      "dns",
      "cloudflare",
      "custom_domain_launch",
      "public_tool_behavior",
      "prototype_expansion",
      "production_readiness"
    ],
    "statement": "Prototype validation does not authorize public workbench, engine, classifier, upload, scoring, API, routes, sitemap, deployment, DNS, Cloudflare, custom domain launch, public tool behavior, prototype expansion, or production readiness."
  },
  "last_reviewed": "2026-06-17"
}
