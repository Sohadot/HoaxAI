{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/public-reference-strategic-reviewer-surface-audit-v1.schema.json",
  "title": "Public Reference Strategic Reviewer Surface Audit v1",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "sprint",
    "status",
    "audit_only",
    "production_route_added",
    "public_route_count_before",
    "public_route_count_after",
    "sitemap_url_count_expected",
    "strategic_reviewer_surfaces_checked",
    "external_use_layers_checked",
    "related_routes_checked",
    "walkthrough_scenarios",
    "total_scenarios",
    "scenarios_passed",
    "scenarios_failed",
    "repairs_applied",
    "boundary_regressions_found",
    "strategic_legibility_confirmed",
    "reviewer_surface_integrity_confirmed",
    "phase_2_support_confirmed",
    "new_decision_created",
    "route_registry_changed",
    "public_file_registry_changed",
    "no_new_routes"
  ],
  "properties": {
    "id": { "const": "public-reference-strategic-reviewer-surface-audit-v1" },
    "sprint": { "const": "Sprint 125" },
    "status": { "const": "public_reference_strategic_reviewer_surface_audit" },
    "audit_only": { "const": true },
    "production_route_added": { "const": false },
    "public_route_count_before": { "const": 104 },
    "public_route_count_after": { "const": 104 },
    "sitemap_url_count_expected": { "const": 104 },
    "walkthrough_scenarios": { "type": "array", "minItems": 24 },
    "total_scenarios": { "type": "integer", "minimum": 24 },
    "new_decision_created": { "type": "boolean" },
    "route_registry_changed": { "const": false },
    "public_file_registry_changed": { "const": false },
    "no_new_routes": { "const": true }
  }
}
