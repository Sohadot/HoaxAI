{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/public-entry-path-integrity-audit-v1.schema.json",
  "title": "Public Entry Path Integrity Audit v1",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "sprint",
    "status",
    "audit_only",
    "phase",
    "phase_entry_path_audit",
    "production_route_added",
    "public_route_count_before",
    "public_route_count_after",
    "sitemap_url_count_expected",
    "route_registry_count_expected",
    "public_file_registry_unchanged",
    "entry_path_records",
    "total_entry_path_records",
    "walkthrough_scenarios",
    "total_scenarios",
    "scenarios_passed",
    "scenarios_failed",
    "public_entry_path_integrity_confirmed",
    "new_decision_created",
    "no_new_routes"
  ],
  "properties": {
    "id": { "const": "public-entry-path-integrity-audit-v1" },
    "sprint": { "const": "Sprint 133" },
    "status": { "const": "public_entry_path_integrity_audit" },
    "audit_only": { "const": true },
    "phase": { "const": "Phase 5" },
    "phase_entry_path_audit": { "const": true },
    "production_route_added": { "const": false },
    "public_route_count_before": { "const": 104 },
    "public_route_count_after": { "const": 104 },
    "sitemap_url_count_expected": { "const": 104 },
    "route_registry_count_expected": { "const": 104 },
    "entry_path_records": { "type": "array", "minItems": 40 },
    "walkthrough_scenarios": { "type": "array", "minItems": 42 },
    "public_entry_path_integrity_confirmed": { "const": true },
    "new_decision_created": { "type": "boolean" },
    "no_new_routes": { "const": true }
  }
}
