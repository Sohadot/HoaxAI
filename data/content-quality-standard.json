{
  "standard_id": "CONTENT-QUALITY-STD-001",
  "name": "Hoax.ai Content Quality and Reference Substance Standard",
  "version": "v1.0.0",
  "status": "governed_internal_content_quality_standard",
  "maturity": "pre_reference_publication_standard",
  "governing_principle": "A page is not reference-grade because it is long. It is reference-grade because it carries governed substance. No public reference page may exist unless its substance can be inspected, mapped, bounded, and validated.",
  "seo_principle": "SEO is allowed only when it clarifies governed reference value, not when it substitutes for it. SEO metadata must not create unsupported claims, tool implications, detector implications, fake/real promises, scoring promises, upload implications, or unsupported authority.",
  "reference_substance_definition": "The governed combination of purpose, definition, scope, boundary, system relationship, claim traceability, source scope, semantic SEO discipline, internal link logic, prohibited misreadings, review status, and technical quality that makes a page useful as part of Hoax.ai reference layer.",
  "substance_is_not": [
    "word_count_alone",
    "keyword_density",
    "decorative_prose",
    "generic_ai_commentary",
    "topical_news_reaction",
    "repeated_slogans",
    "thin_glossary_text",
    "search_volume_capture",
    "unsourced_external_claims",
    "invented_authority",
    "fake_real_examples",
    "sensational_fraud_framing",
    "tool_promise_language"
  ],
  "minimum_substance_gates": [
    "purpose_gate",
    "definition_gate",
    "scope_gate",
    "governance_boundary_gate",
    "system_relationship_gate",
    "claim_traceability_gate",
    "source_scope_gate",
    "semantic_seo_discipline_gate",
    "prohibited_misreading_gate",
    "internal_link_gate",
    "technical_quality_gate",
    "interface_boundary_gate",
    "publisher_boundary_gate",
    "review_status_gate"
  ],
  "required_page_section_classes": [
    "page_thesis",
    "definition_and_scope",
    "governance_boundary",
    "relationship_to_hoax_system",
    "semantic_seo_role",
    "prohibited_misreadings",
    "claim_and_source_traceability",
    "internal_links",
    "last_reviewed"
  ],
  "conditional_page_section_classes": [
    "taxonomy_relationship",
    "standard_relationship",
    "protocol_relationship",
    "output_boundary_relationship",
    "source_scope_notes",
    "related_reference_concepts",
    "publisher_candidate_notes",
    "candidate_route_notes",
    "public_claim_mapping_notes"
  ],
  "prohibited_content_quality_failures": [
    "thin_seo",
    "keyword_only",
    "glossary_only_without_governance",
    "generic_ai_commentary",
    "unsupported_external_claims",
    "placeholder_page",
    "future_capability_teaser",
    "tool_implication",
    "scoring_implication",
    "fake_real_verdict_implication",
    "subject_accusation",
    "publisher_output_without_approval",
    "search_volume_first_page",
    "numeric_quality_score",
    "seo_score",
    "percentage_grade"
  ],
  "validation_requirements": [
    "substance_gates_pass_fail_only",
    "no_numeric_content_scores",
    "no_seo_scores_or_grades",
    "validate_all_py_required_before_public_release",
    "publisher_remains_blocked_until_public_route_readiness_gate"
  ],
  "last_reviewed": "2026-06-17"
}
