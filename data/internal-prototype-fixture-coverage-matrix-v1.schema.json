{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/internal-prototype-fixture-coverage-matrix-v1.schema.json",
  "title": "Internal Prototype Fixture Coverage Matrix v1",
  "type": "object",
  "required": [
    "coverage_matrix_id",
    "version",
    "status",
    "decision_ref",
    "sprint",
    "public_route_authorized",
    "public_benchmark_authorized",
    "public_report_authorized",
    "output_generator_authorized",
    "scoring_authorized",
    "api_authorized",
    "javascript_authorized",
    "source_authority",
    "coverage_status_vocabulary",
    "current_fixture_inventory",
    "coverage_dimensions",
    "posture_state_coverage",
    "evidence_condition_dimension_coverage",
    "protocol_step_coverage",
    "standard_principle_coverage",
    "boundary_check_coverage",
    "caveat_family_coverage",
    "guardrail_rule_coverage",
    "forbidden_transformation_coverage",
    "traceability_field_coverage",
    "fixture_policy_coverage",
    "regression_vector_coverage",
    "coverage_gaps",
    "future_fixture_admission_criteria",
    "forbidden_fixture_classes",
    "operational_boundaries"
  ],
  "properties": {
    "coverage_matrix_id": {
      "type": "string",
      "const": "internal-prototype-fixture-coverage-matrix-v1"
    },
    "version": { "type": "string" },
    "status": {
      "type": "string",
      "const": "internal_non_public_fixture_coverage_matrix"
    },
    "decision_ref": {
      "type": "string",
      "const": "DEC-093"
    },
    "sprint": {
      "type": "string",
      "const": "Sprint 75"
    },
    "public_route_authorized": { "type": "boolean", "const": false },
    "public_benchmark_authorized": { "type": "boolean", "const": false },
    "public_report_authorized": { "type": "boolean", "const": false },
    "output_generator_authorized": { "type": "boolean", "const": false },
    "scoring_authorized": { "type": "boolean", "const": false },
    "api_authorized": { "type": "boolean", "const": false },
    "javascript_authorized": { "type": "boolean", "const": false },
    "source_authority": {
      "type": "array",
      "allOf": [
        { "contains": { "const": "evidence_posture_standard_v1" } },
        { "contains": { "const": "evidence_posture_protocol_v1_draft" } },
        { "contains": { "const": "engine_boundary_charter" } },
        { "contains": { "const": "evidence_posture_engine_model_v0" } },
        { "contains": { "const": "output_language_guardrail_model_v1" } },
        { "contains": { "const": "internal_non_public_engine_prototype_charter" } },
        { "contains": { "const": "internal_prototype_fixture_policy" } },
        { "contains": { "const": "controlled_internal_prototype_v0_authorization_package" } },
        { "contains": { "const": "controlled_internal_prototype_v0_implementation" } },
        { "contains": { "const": "controlled_internal_prototype_v0_hardening" } },
        { "contains": { "const": "internal_prototype_traceability_interpretability_audit_v1" } }
      ]
    },
    "coverage_status_vocabulary": {
      "type": "array",
      "allOf": [
        { "contains": { "const": "Covered" } },
        { "contains": { "const": "Partially Covered" } },
        { "contains": { "const": "Gap" } },
        { "contains": { "const": "Not Applicable" } },
        { "contains": { "const": "Future Candidate" } }
      ]
    },
    "current_fixture_inventory": { "type": "object" },
    "coverage_dimensions": { "type": "array", "minItems": 11 },
    "posture_state_coverage": { "type": "object", "minProperties": 5 },
    "evidence_condition_dimension_coverage": { "type": "object", "minProperties": 13 },
    "protocol_step_coverage": { "type": "object", "minProperties": 17 },
    "standard_principle_coverage": { "type": "object", "minProperties": 14 },
    "boundary_check_coverage": { "type": "object", "minProperties": 9 },
    "caveat_family_coverage": { "type": "object", "minProperties": 9 },
    "guardrail_rule_coverage": { "type": "object", "minProperties": 5 },
    "forbidden_transformation_coverage": { "type": "object", "minProperties": 9 },
    "traceability_field_coverage": { "type": "object", "minProperties": 14 },
    "fixture_policy_coverage": { "type": "object", "minProperties": 5 },
    "regression_vector_coverage": { "type": "object", "minProperties": 3 },
    "coverage_gaps": { "type": "array", "minItems": 1 },
    "future_fixture_admission_criteria": {
      "type": "object",
      "required": ["requires_named_coverage_gap_reference"],
      "properties": {
        "requires_named_coverage_gap_reference": { "type": "boolean", "const": true }
      }
    },
    "forbidden_fixture_classes": { "type": "array", "minItems": 13 },
    "operational_boundaries": {
      "type": "object",
      "required": [
        "no_public_benchmark",
        "no_public_report",
        "no_public_engine",
        "no_output_generator",
        "no_upload",
        "no_scoring",
        "no_api",
        "no_javascript",
        "no_public_tool_behavior"
      ],
      "properties": {
        "no_public_benchmark": { "type": "boolean", "const": true },
        "no_public_report": { "type": "boolean", "const": true },
        "no_public_engine": { "type": "boolean", "const": true },
        "no_output_generator": { "type": "boolean", "const": true },
        "no_upload": { "type": "boolean", "const": true },
        "no_scoring": { "type": "boolean", "const": true },
        "no_api": { "type": "boolean", "const": true },
        "no_javascript": { "type": "boolean", "const": true },
        "no_public_tool_behavior": { "type": "boolean", "const": true }
      }
    }
  },
  "additionalProperties": true
}
